# OCI config location and profile
OCI_CONFIG_FILE=/opt/arm-hunter/config
OCI_PROFILE=DEFAULT

# Optional override. Empty means tenancy from OCI config.
COMPARTMENT_ID=

# Optional override. Empty means auto-discover public subnet.
SUBNET_ID=

# Launch options
DISPLAY_NAME=Binance-Bot-ARM-Ubuntu24
SHAPE=VM.Standard.A1.Flex

# Default single profile (used when PROFILE_MATRIX is empty)
OCPUS=4
MEMORY_GBS=24

# Multi-profile strategy (small-to-large recommended)
# Format: OCPU:MEMORY_GB entries separated by comma
# Example below tries 1/6 then 2/12 then 4/24 in each cycle.
PROFILE_MATRIX=1:6,2:12,4:24
PREFER_SMALL_FIRST=true

# SSH key metadata options (choose one)
SSH_PUBLIC_KEY=
SSH_PUBLIC_KEY_FILE=/opt/arm-hunter/id_rsa.pub

# Optional region override
OCI_REGION=

# Auto cleanup after first successful launch / detection
CLEANUP_ON_SUCCESS=true
SUCCESS_CLEANUP_CMD=/opt/arm-hunter/cleanup_hunter.sh --success
